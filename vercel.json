{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/*.js": {
      "memory": 128,
      "maxDuration": 5
    }
  },
  "rewrites": [
    { "source": "/perplexity", "destination": "/api/perplexity" },
    { "source": "/analytics", "destination": "/analytics.html" }
  ]
}
